{
  "name": "@laguna-team/whitelabel-sdk",
  "version": "0.1.2",
  "description": "Official TypeScript SDK for the Laguna Whitelabel API — embed cashback in your app, mint affiliate links, and verify webhooks.",
  "license": "MIT",
  "author": "Laguna <team@laguna.network>",
  "homepage": "https://laguna.network",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Laguna-Team/laguna-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Laguna-Team/laguna-sdk/issues"
  },
  "keywords": [
    "laguna",
    "cashback",
    "affiliate",
    "whitelabel",
    "api",
    "sdk"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
